{
  "name": "clean-robot-frontend",
  "private": true,
  "version": "0.1.0-rc.2",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config=playwright.live.config.ts",
    "test:e2e:live:readonly": "playwright test --config=playwright.live.config.ts --grep @live-readonly",
    "test:e2e:live:write": "playwright test --config=playwright.live.config.ts --grep @live-write",
    "test:e2e:live:write:slam": "playwright test --config=playwright.live.config.ts --grep @live-write-slam",
    "test:e2e:live:write:task": "playwright test --config=playwright.live.config.ts --grep @live-write-task",
    "test:e2e:live:write:schedule": "playwright test --config=playwright.live.config.ts --grep @live-write-schedule",
    "test:e2e:live:write:map": "playwright test --config=playwright.live.config.ts --grep @live-write-map",
    "test:tablet-ui": "node ./scripts/smoke-tablet-ui.mjs",
    "audit:modules": "node ./scripts/audit-local-modules.mjs",
    "audit:actuator-contract": "node ./scripts/audit-actuator-contract.mjs",
    "audit:legacy": "node ./scripts/audit-legacy-boundaries.mjs",
    "audit:production": "node ./scripts/audit-production-package.mjs",
    "verify": "npm run lint && npm run audit:modules && npm run audit:actuator-contract && npm run audit:legacy && npm run test:tablet-ui && npm run test && npm run build && npm run audit:production",
    "clean:workspace": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\clean-workspace.ps1",
    "clean:workspace:deep": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\clean-workspace.ps1 -IncludeReleaseBackups",
    "clean:workspace:release": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\clean-workspace.ps1 -IncludeReleaseBundles",
    "package:trial": "npm run verify && node ./scripts/package-trial.mjs",
    "gateway:dev": "node ./site-gateway/server.mjs --host 127.0.0.1 --port 4180",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\install-site-service.ps1",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\uninstall-site-service.ps1",
    "start:prod": "node ./site-gateway/server.mjs --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.0",
    "antd": "^6.3.3",
    "konva": "^10.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "roslib": "^2.1.0",
    "ws": "^8.18.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.4"
  }
}
